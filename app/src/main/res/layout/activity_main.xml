<RelativeLayout
    xmlns:android = "http://schemas.android.com/apk/res/android"
    xmlns:tools = "http://schemas.android.com/tools"
    android:layout_width =  "match_parent"
    android:layout_height = "match_parent" >

    <LinearLayout
        android:id="@+id/ll1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/ll2"
        android:layout_marginBottom="8dp" >

        <ImageView
            android:id="@+id/setCoordinates"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="110dp"
            android:src="@drawable/set_position"/>

        <ImageView
            android:id="@+id/liveLocation"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="110dp"
            android:src="@drawable/live_location"/>

    </LinearLayout>

    <LinearLayout
        android:layout_above="@+id/view"
        android:id="@+id/ll2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Set Coordinates"
            android:gravity="center"
            android:textAppearance="?android:textAppearanceMedium"
            android:textColor="#000"/>

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Track Location"
            android:gravity="center"
            android:textAppearance="?android:textAppearanceMedium"
            android:textColor="#000"/>

    </LinearLayout>

    <View
        android:id="@+id/view"
        android:layout_centerInParent="true"
        android:layout_width="wrap_content"
        android:layout_height="2dp"/>

    <LinearLayout
        android:id="@+id/ll3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/view"
        android:layout_marginTop="32dp">

        <ImageView
            android:id="@+id/bulkyWaste"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="110dp"
            android:src="@drawable/garbage_icon"/>

        <ImageView
            android:id="@+id/binStatus"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="110dp"
            android:src="@drawable/bin_status" />

    </LinearLayout>

    <LinearLayout
        android:layout_below="@+id/ll3"
        android:id="@+id/ll4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Bulky Spots"
            android:gravity="center"
            android:textAppearance="?android:textAppearanceMedium"
            android:textColor="#000"/>

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Bin Status"
            android:gravity="center"
            android:textAppearance="?android:textAppearanceMedium"
            android:textColor="#000"/>

    </LinearLayout>

